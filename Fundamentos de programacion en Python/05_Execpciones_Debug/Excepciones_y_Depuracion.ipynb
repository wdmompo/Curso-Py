    "# Ejemplo de logging en vez de prints\n",
    "import logging\n",
    "logging.basicConfig(level=logging.DEBUG, format='%(levelname)s:%(message)s')\n",
    "\n",
    "def proceso(x):\n",
    "    logging.debug('Entrando en proceso con x=%s', x)\n",
    "    if x < 0:\n",
    "        logging.warning('x es negativo: %s', x)\n",
    "    return x * 2\n",
    "\n",
    "print(proceso(3))\n",
    "print(proceso(-1))\n"
   ]
